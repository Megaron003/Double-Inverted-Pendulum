<mujoco model="acrobot">
    <option gravity="0 0 -9.81" timestep="0.02"/>

    <worldbody>
        <body name="base">

            <body name="link1">
                <joint name="hinge1" type="hinge" axis="0 1 0"/>

                <geom type="capsule"
                      fromto="0 0 0 0 0 1"
                      size="0.05"
                      mass="1"/>

                <body name="link2" pos="0 0 1">
                    <joint name="hinge2" type="hinge" axis="0 1 0"/>

                    <geom type="capsule"
                          fromto="0 0 0 0 0 1"
                          size="0.05"
                          mass="1"/>
                </body>

            </body>
        </body>
    </worldbody>

    <actuator>
        <motor joint="hinge2"
               ctrlrange="-1 1"
               ctrllimited="true"
               gear="1"/>
    </actuator>
</mujoco>