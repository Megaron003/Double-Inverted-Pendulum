<mujoco model="double_inverted_pendulum">
  <option gravity="0 0 -9.81" timestep="0.02" integrator="RK4"/>

  <worldbody>
    <light name="light" pos="0 0 3"/>
    <body name="base" pos="0 0 1">
      <joint name="theta1" type="hinge" axis="0 1 0" damping="0.1" limited="true" range="-3.14 3.14"/>
      <geom type="capsule" fromto="0 0 0 0 0 0.5" size="0.03" mass="1" rgba="0.8 0.2 0.2 1"/>

      <body name="link2" pos="0 0 0.5">
        <joint name="theta2" type="hinge" axis="0 1 0" damping="0.1" limited="true" range="-3.14 3.14"/>
        <geom type="capsule" fromto="0 0 0 0 0 0.5" size="0.03" mass="1" rgba="0.2 0.8 0.2 1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="tau1" joint="theta1" ctrlrange="-10 10" gear="1"/>
    <motor name="tau2" joint="theta2" ctrlrange="-10 10" gear="1"/>
  </actuator>
</mujoco>